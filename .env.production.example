# ===========================================
# CEOClaw Production Environment Variables
# ===========================================
# Copy this file and fill in your values in Vercel Dashboard
# Project Settings → Environment Variables

# ===========================================
# AI PROVIDERS (at least one required)
# ===========================================

# OpenRouter API Key (recommended - Gemini 3.1 Lite)
# Get yours: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ZAI API Key (GLM-5)
# Get yours: https://open.bigmodel.cn/
ZAI_API_KEY=your-zai-api-key-here

# OpenAI API Key (optional - GPT-5.2)
# Get yours: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# ===========================================
# DATABASE (optional - demo mode works without it)
# ===========================================

# PostgreSQL URL (Neon, Supabase, etc.)
# POSTGRES_URL=postgresql://user:pass@host/db?sslmode=require
# POSTGRES_PRISMA_URL=postgresql://user:pass@host/db?sslmode=require
# POSTGRES_URL_NON_POOLING=postgresql://user:pass@host/db?sslmode=require

# ===========================================
# APP CONFIGURATION
# ===========================================

# App URL (your Vercel deployment URL)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# App Name
NEXT_PUBLIC_APP_NAME=CEOClaw

# Demo Mode (set to "false" in production with database)
APP_DATA_MODE=demo

# Skip Auth (development only - set to "false" in production)
CEOCLAW_SKIP_AUTH=true

# ===========================================
# OPTIONAL INTEGRATIONS
# ===========================================

# Telegram Bot Token (optional)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF

# Telegram Chat ID (optional)
# TELEGRAM_CHAT_ID=-1001234567890

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret

# GitHub OAuth (optional)
# GITHUB_CLIENT_ID=your-client-id
# GITHUB_CLIENT_SECRET=your-client-secret

# ===========================================
# MONITORING (optional)
# ===========================================

# Sentry DSN (error tracking)
# NEXT_PUBLIC_SENTRY_DSN=https://key@sentry.io/project

# Analytics ID (Google Analytics)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
